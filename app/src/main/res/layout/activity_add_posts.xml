<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAC0F0">

    <TextView
        android:id="@+id/tvAddPost"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:text="Add Post"
        android:textColor="#5E548E"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnAddImage"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginEnd="24dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Add Image"
        android:scaleType="fitCenter"
        android:src="@android:drawable/ic_menu_camera"
        app:layout_constraintBottom_toBottomOf="@id/tvAddPost"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvAddPost"
        app:layout_constraintVertical_bias="0.0"
        app:tint="#5E548E" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#F7DCFD"
        app:cardCornerRadius="30dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvAddPost">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Title"
                android:textColor="#5E548E"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/edittext"
                android:hint="Title"
                android:padding="12dp"
                android:textColorHint="#BCB5D7" />

            <EditText
                android:id="@+id/etContent"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/edittext"
                android:gravity="top"
                android:hint="Write something..."
                android:padding="12dp"
                android:textColorHint="#BCB5D7" />

            <ImageView
                android:id="@+id/ivSelectedImage"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="12dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:clipToOutline="true"
                android:background="@drawable/edittext" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:columnCount="2"
                android:alignmentMode="alignMargins">

                <Button
                    android:id="@+id/btnRunning"
                    style="@style/WorkoutButtonStyle"
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:backgroundTint="#D1E9F6"
                    android:text="Running"
                    android:textColor="#2D6A4F"
                    app:icon="@drawable/ic_running"
                    app:iconTint="#2D6A4F" />

                <Button
                    android:id="@+id/btnStrength"
                    style="@style/WorkoutButtonStyle"
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:backgroundTint="#EADCF7"
                    android:text="Strength"
                    android:textColor="#5E548E"
                    app:icon="@drawable/ic_strength"
                    app:iconTint="#5E548E" />

                <Button
                    android:id="@+id/btnCardio"
                    style="@style/WorkoutButtonStyle"
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:backgroundTint="#FAD2E1"
                    android:text="Cardio"
                    android:textColor="#C2185B"
                    app:icon="@drawable/ic_cardio"
                    app:iconTint="#C2185B" />

                <Button
                    android:id="@+id/btnPilates"
                    style="@style/WorkoutButtonStyle"
                    android:layout_width="0dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:backgroundTint="#D0E1F9"
                    android:text="Pilates"
                    android:textColor="#1A4375"
                    app:icon="@drawable/ic_pilates"
                    app:iconTint="#1A4375" />
            </GridLayout>

            <Button
                android:id="@+id/btnPost"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="#E5989B"
                android:text="Post"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                app:cornerRadius="30dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>