<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FBE5ED"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivUserProfile"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_user"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" /> <TextView
        android:id="@+id/tvUserNameProfile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="User Name"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#03124B"
        android:layout_marginEnd="15dp"
        app:layout_constraintTop_toTopOf="@id/ivUserProfile"
        app:layout_constraintBottom_toBottomOf="@id/ivUserProfile"
        app:layout_constraintEnd_toStartOf="@id/ivUserProfile" /> <LinearLayout
        android:id="@+id/layoutStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="25dp"
        android:weightSum="4"
        app:layout_constraintTop_toBottomOf="@id/ivUserProfile">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#FACDBE"
            app:cardCornerRadius="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="8dp" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_fire"/>
                <TextView android:id="@+id/tvStreakCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textStyle="bold" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Streak" android:textSize="9sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#9DF8E845"
            app:cardCornerRadius="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="8dp" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_star"/>
                <TextView android:id="@+id/tvTotalStars" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textStyle="bold" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Stars" android:textSize="9sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#77FD9FBE"
            app:cardCornerRadius="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="8dp" android:gravity="center" android:orientation="vertical">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_calendar"/>
                <TextView android:id="@+id/tvDaysLogs" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textStyle="bold" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Logs" android:textSize="9sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="#3D39A8F6"
            app:cardCornerRadius="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="8dp" android:gravity="center" android:orientation="vertical">
                <ImageView
                    android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_workout"/>
                <TextView android:id="@+id/tvTotalWorkouts" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textStyle="bold" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Workouts" android:textSize="9sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

        <TextView
            android:id="@+id/tvGraphTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Activity Overview"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#03124B"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/layoutStats"
            app:layout_constraintStart_toStartOf="parent" />

        <com.github.mikephil.charting.charts.BarChart
            android:id="@+id/barChart"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvGraphTitle" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardGeneralInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="15dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/barChart">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="15dp">

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="General Information" android:textStyle="bold"
                        android:textColor="#03124B"/>
                    <Button android:id="@+id/btnEditProfile" style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true" android:text="Add Details"
                        android:backgroundTint="#03124B"
                        android:textColor="#FFFFFF"
                        android:paddingLeft="24dp"
                        android:paddingRight="24dp"
                        android:layout_marginTop="16dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:textAllCaps="false" />
                </RelativeLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:weightSum="4" android:layout_marginTop="10dp">
                    <TextView android:id="@+id/tvAge" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Age 0" android:gravity="center" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvHeight" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0 cm" android:gravity="center" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvWeight" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0 kg" android:gravity="center" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvBMI" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="BMI 0.0" android:gravity="center" android:textStyle="bold" android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnMyPosts"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="25dp"
            android:layout_marginBottom="20dp"
            android:text="My Posts"
            android:textAllCaps="false"
            android:backgroundTint="#95AAF4"
            app:cornerRadius="30dp"
            app:layout_constraintTop_toBottomOf="@id/cardGeneralInfo"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>